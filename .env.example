# Copy to .env (or just export these) to enable the optional LLM layers.
# The platform runs fully WITHOUT a key — it falls back to a deterministic,
# template-based rationale and the deterministic recommendation engine.

# v2: the LLM layer was migrated from Anthropic to OpenAI.
# OPENAI_API_KEY=sk-...

# Cost-aware two-tier router. Cheap model is the default for everything; the
# reasoning agent only escalates to the strong model when its self-reflection is weak.
# TICKER_LLM_TIER_CHEAP=gpt-4o-mini
# TICKER_LLM_TIER_STRONG=gpt-4o

# Optional hard ceiling (USD) on a single /api/reason run. 0 disables the cap.
# TICKER_REASONING_BUDGET_USD=0.05

# Data source: "auto" (live yfinance, fall back to fixtures), "live", or "fixture".
# Use "fixture" for fully offline / deterministic demos and evals.
# TICKER_DATA_SOURCE=auto
