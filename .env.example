# Copy to .env (or just export these) to enable the optional LLM narrative layer.
# The platform runs fully WITHOUT a key — it falls back to a deterministic,
# template-based rationale. The key only upgrades the *prose* of the report.

# ANTHROPIC_API_KEY=sk-ant-...

# Model used for narrative synthesis (optional). Defaults to claude-opus-4-8.
# TICKER_LLM_MODEL=claude-opus-4-8

# Data source: "auto" (live yfinance, fall back to fixtures), "live", or "fixture".
# Use "fixture" for fully offline / deterministic demos and evals.
# TICKER_DATA_SOURCE=auto
